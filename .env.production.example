# =====================================================================
# OrderDesk — PRODUCTION environment
# Copy this to ".env" on your VPS (next to docker-compose.prod.yml) and
# fill every value. Compose reads this file for BOTH build args and runtime.
# Never commit the real .env.
# =====================================================================

# --- Database ---------------------------------------------------------
# POSTGRES_PASSWORD is used by the db container AND must match DATABASE_URL.
# Host is the compose service name "db", not localhost.
POSTGRES_PASSWORD="CHANGE_ME_strong_db_password"
DATABASE_URL="postgresql://orderdesk:CHANGE_ME_strong_db_password@db:5432/orderdesk"

# --- Auth mode --------------------------------------------------------
AUTH_MODE="clerk"

# --- Clerk (production instance keys: pk_live… / sk_live…) -------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"

# --- Self-service provisioning ---------------------------------------
# First Clerk login with this email becomes ADMIN.
ADMIN_EMAIL="you@yourcompany.com"

# --- Public URL (used for invite links, OAuth redirect, same-origin) --
# MUST be your real https domain.
NEXT_PUBLIC_APP_URL="https://orderdesk.example.com"

# --- Traefik routing --------------------------------------------------
# Host-mode Traefik routes to the app by the Host() rule below. The entrypoint
# (websecure) and cert resolver (letsencrypt) are hardcoded in the compose file
# to match your Traefik, so only the domain is needed here.
APP_DOMAIN="orderdesk.example.com"   # host only, no https://

# --- Encryption key (SMTP passwords, OAuth refresh tokens) ------------
# Generate ONCE:  openssl rand -hex 32
# WARNING: changing this later makes existing encrypted data unreadable.
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_32"

# --- Global SMTP fallback (optional; per-user SMTP overrides this) -----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="OrderDesk <you@yourcompany.com>"

# --- Google OAuth "Connect Gmail" (optional) --------------------------
# Redirect URI in Google Cloud must be:
#   https://orderdesk.example.com/api/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
