# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://orderdesk:orderdesk@localhost:5432/orderdesk"

# --- Auth mode ---
# "dev"   = local login-as seeded users (no external service)
# "clerk" = production identity provider (set the keys below)
AUTH_MODE="dev"

# --- Clerk (only required when AUTH_MODE=clerk) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""

# --- Self-service provisioning ---
# On first Clerk login with no matching record, this email is provisioned as ADMIN;
# every other new login becomes a MANAGER (can create orders, not products).
ADMIN_EMAIL=""

# Public app URL (used for same-origin checks + invite links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (SMTP) for invite notifications ---
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=<your gmail>,
# SMTP_PASS=<16-char app password, spaces removed>. Leave blank to disable email.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""

# --- Encryption key for sensitive fields (SMTP passwords, OAuth tokens) ---
ENCRYPTION_KEY="change-me-in-production-use-a-long-random-string"

# --- Google OAuth2 for "Connect Gmail" SMTP (optional) ---
# OAuth client (type: Web application) from Google Cloud Console. Redirect URI:
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
# Leave blank to hide the one-click Google connect button.
GOOGLE_CLIENT_ID="350011333706-fvbq31iedl44luculdonuq31tba33k4m.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"
