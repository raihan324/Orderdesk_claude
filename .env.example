# =====================================================================
# OrderDesk — local development environment (TEMPLATE)
# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" — it contains secrets.
# =====================================================================

# --- Database (matches docker-compose.yml) ---
# Local docker default:
# DATABASE_URL="postgresql://orderdesk:orderdesk@localhost:5432/orderdesk"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/orderdesk"

# --- Auth mode ---
# "dev"   = local login-as seeded users (no external service)
# "clerk" = production identity provider (set the keys below)
AUTH_MODE="clerk"

# --- Clerk (only required when AUTH_MODE=clerk) ---
# Get these from the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"

# Tell Clerk where the sign-in page lives and where to go after login
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard

# --- Self-service provisioning ---
# First Clerk login with this email is provisioned as ADMIN; all other new logins
# become MANAGER (can create orders, not products).
ADMIN_EMAIL="you@example.com"

# Public app URL (used for same-origin checks + invite links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (SMTP) for invite notifications ---
# Gmail app password (spaces removed). Leave SMTP_* blank to disable email sending.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="you@example.com"
SMTP_PASS="your-app-password"
MAIL_FROM="OrderDesk <you@example.com>"

# --- Encryption key for sensitive fields (passwords, etc) ---
# Generate one with:  openssl rand -hex 32
# WARNING: changing this later makes existing encrypted data unreadable.
ENCRYPTION_KEY="change-me-in-production-use-a-long-random-string"

# --- Google OAuth2 for "Connect Gmail" SMTP (optional) ---
# Create an OAuth client (type: Web application) in Google Cloud Console and add
# the redirect URI:  ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
# Leave blank to hide the one-click Google connect button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
